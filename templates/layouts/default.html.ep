<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
      <style>
      .post-content p {
        margin-bottom: 1rem;
      }

      .post-content ul,
      .post-content ol {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
      }

      .post-content h1,
      .post-content h2,
      .post-content h3 {
        margin-top: 1.5rem;
        margin-bottom: 1rem;
      }

      .post-content pre {
        background: #f8f9fa;
        padding: 10px;
        border-radius: 6px;
      }
      </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">BlogApp</a>
      <div class="d-flex">
        % if (session 'user_id') {
          <span class="navbar-text text-white me-3">
            Logged in as <%= session 'username' %>
          </span>
          <%=link_to 'Logout'=>'/logout' , class => 'btn btn-outline-light btn-sm'%>
        % } else {
          <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
        % }
      </div>
    </div>
  </nav>
<%= content %>
  </body>
</html>